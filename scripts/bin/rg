#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"

# Prefer a real ripgrep binary if available outside this shim path.
find_real_rg() {
  local cleaned_path=""
  local dir=""
  IFS=':' read -r -a path_items <<< "$PATH"
  for dir in "${path_items[@]}"; do
    if [ -z "$dir" ]; then
      continue
    fi
    if [ "$dir" = "$(dirname "$SCRIPT_PATH")" ]; then
      continue
    fi
    if [ -z "$cleaned_path" ]; then
      cleaned_path="$dir"
    else
      cleaned_path="${cleaned_path}:$dir"
    fi
  done

  PATH="$cleaned_path" command -v rg || true
}

real_rg="$(find_real_rg)"
if [ -n "$real_rg" ] && [ "$real_rg" != "$SCRIPT_PATH" ]; then
  exec "$real_rg" "$@"
fi

# Fallback compatibility mode using grep for the subset used in this repo.
quiet=0
fixed=0
line_number=0
only_matching=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    -q)
      quiet=1
      shift
      ;;
    -F)
      fixed=1
      shift
      ;;
    -n)
      line_number=1
      shift
      ;;
    -o)
      only_matching=1
      shift
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "rg shim unsupported flag: $1" >&2
      exit 2
      ;;
    *)
      break
      ;;
  esac
done

if [ "$#" -lt 1 ]; then
  echo "rg shim requires a pattern" >&2
  exit 2
fi

pattern="$1"
shift

grep_args=()
if [ "$quiet" = "1" ]; then
  grep_args+=("-q")
fi
if [ "$line_number" = "1" ]; then
  grep_args+=("-n")
fi
if [ "$fixed" = "1" ]; then
  grep_args+=("-F")
else
  grep_args+=("-E")
fi
if [ "$only_matching" = "1" ]; then
  grep_args+=("-o")
fi

if [ "$#" -eq 0 ]; then
  grep "${grep_args[@]}" -- "$pattern"
else
  grep "${grep_args[@]}" -- "$pattern" "$@"
fi
