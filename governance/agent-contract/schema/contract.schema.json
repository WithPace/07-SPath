{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StarPath Agent Contract",
  "type": "object",
  "required": [
    "version",
    "meta",
    "principles",
    "workflow",
    "modules"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "meta": {
      "type": "object",
      "required": [
        "project",
        "applies_to"
      ],
      "properties": {
        "project": {
          "type": "string",
          "minLength": 1
        },
        "applies_to": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "principles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "statement"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "statement": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "workflow": {
      "type": "object",
      "required": [
        "stages"
      ],
      "properties": {
        "stages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "modules": {
      "type": "object",
      "required": [
        "required"
      ],
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "base_path": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
